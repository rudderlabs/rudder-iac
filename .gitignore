# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# IDEs
.vscode

# Log files
*.log

# Added by goreleaser init:
dist/

# Generated validation rule catalog (produced as a CI build artifact via
# `make gen-rule-docs`, not committed)
docs/generated/

# Cline memory-bank
memory-bank


**/linear-task-**.mdc

# Rudder typer platform specific
.gradle
.idea
cli/internal/typer/generator/platforms/kotlin/testdata/validator/build
cli/internal/typer/generator/platforms/kotlin/testdata/validator/gradle
# create-vhs demo recordings. GIFs are committed so they embed in DEMOS.md;
# MP4s + generated tapes stay out (regenerate with docs/demos/record-demos.sh).
docs/demos/**/recording.mp4
docs/demos/**/tape.tape
