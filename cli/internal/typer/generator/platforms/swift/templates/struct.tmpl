{{- /*
    "structwithindent" is a named template so it can be called recursively for nested structs.
    It receives a slice: [indentLevel int, struct SwiftStruct].
    The indent level is unused here — indentation is applied by the caller via the `indent` func.
*/ -}}
{{- define "structwithindent" -}}
{{- $struct := (index . 1) -}}
{{- with $struct -}}
{{- if .Comment }}
/// {{ escapeComment .Comment }}
{{- end }}
public struct {{ .Name }} {
{{- range .Properties }}
{{- if .Comment }}
    /// {{ escapeComment .Comment }}
{{- end }}
    public var {{ .Name }}: {{ .Type }}{{ if .Optional }}?{{ end }}
{{- end }}
{{- range .NestedStructs }}
{{ include "structwithindent" (mkSlice 1 .) | indent 1 }}
{{- end }}

    public init(
{{- $hasRequired := false }}
{{- range .Properties }}{{- if not .Optional }}{{- $hasRequired = true }}{{- end }}{{- end }}
{{- $hasOptional := false }}
{{- range .Properties }}{{- if .Optional }}{{- $hasOptional = true }}{{- end }}{{- end }}
{{- range $i, $p := .Properties }}
{{- if not $p.Optional }}
{{- if $i }},
        {{ end }}{{ $p.Name }}: {{ $p.Type }}
{{- end }}
{{- end }}
{{- if and $hasRequired $hasOptional }},
        {{ end }}
{{- range $i, $p := .Properties }}
{{- if $p.Optional }}
{{- if $i }},
        {{ end }}{{ $p.Name }}: {{ $p.Type }}? = nil
{{- end }}
{{- end }}
    ) {
{{- range .Properties }}
        self.{{ .Name }} = {{ .Name }}
{{- end }}
    }

    {{- /*
        SerializeMethod is either "toProperties" (track/screen events) or "toTraits" (identify/group).
        Required properties go directly into the initial dictionary literal.
        Optional properties are appended only if non-nil using `if let` unwrapping.
        SerializeExpr is pre-computed by the generator per property type:
            plain primitive   → property name (e.g. "email")
            String/Int enum   → "deviceType.rawValue"
            multi-type enum   → "pageType.value"
            nested struct     → "address.toProperties()"
            variant enum      → "pageType.toProperties()"
    */ -}}
    public func {{ .SerializeMethod }}() -> [String: Any] {
{{- if $hasRequired }}
        var props: [String: Any] = [
{{- range $i, $p := .Properties }}
{{- if not $p.Optional }}
{{- if $i }},
{{ end }}
            "{{ escapeString $p.SerialName }}": {{ $p.SerializeExpr }}
{{- end }}
{{- end }}
        ]
{{- else }}
        var props: [String: Any] = [:]
{{- end }}
{{- range .Properties }}
{{- if .Optional }}
        if let {{ .Name }} = {{ .Name }} { props["{{ escapeString .SerialName }}"] = {{ .SerializeExpr }} }
{{- end }}
{{- end }}
        return props
    }
}
{{- end }}
{{- end }}
