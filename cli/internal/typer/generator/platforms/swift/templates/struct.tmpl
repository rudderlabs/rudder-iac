{{- /*
    "structwithindent" is a named template so it can be called recursively for nested structs.
    It receives a slice: [indentLevel int, struct SwiftStruct].
    The indent level is unused here — indentation is applied by the caller via the `indent` func.
*/ -}}
{{- define "structwithindent" -}}
{{- $struct := (index . 1) -}}
{{- with $struct -}}
{{- if .Comment }}
/// {{ escapeComment .Comment }}
{{- end }}
public struct {{ .Name }} {
{{- range .Properties }}
{{- if .Comment }}
    /// {{ escapeComment .Comment }}
{{- end }}
{{- if .ConstantValue }}
    public let {{ .Name }}: {{ .Type }} = {{ .ConstantValue }}
{{- else }}
    public var {{ .Name }}: {{ .Type }}{{ if .Optional }}?{{ end }}
{{- end }}
{{- end }}
{{- range .NestedStructs }}
{{ include "structwithindent" (mkSlice 1 .) | indent 1 }}
{{- end }}

{{- $hasRequired := false }}
{{- range .Properties }}{{- if not .Optional }}{{- $hasRequired = true }}{{- end }}{{- end }}
{{- $hasNonConstant := false }}
{{- range .Properties }}{{- if not .ConstantValue }}{{- $hasNonConstant = true }}{{- end }}{{- end }}
{{- if $hasNonConstant }}
    public init(
{{- $needComma := false }}
{{- range .Properties }}
{{- if not .ConstantValue }}
{{- if not .Optional }}
{{- if $needComma }},{{ end }}
        {{ .Name }}: {{ .Type }}
{{- $needComma = true }}
{{- end }}
{{- end }}
{{- end }}
{{- range .Properties }}
{{- if not .ConstantValue }}
{{- if .Optional }}
{{- if $needComma }},{{ end }}
        {{ .Name }}: {{ .Type }}? = nil
{{- $needComma = true }}
{{- end }}
{{- end }}
{{- end }}
    ) {
{{- range .Properties }}
{{- if not .ConstantValue }}
        self.{{ .Name }} = {{ .Name }}
{{- end }}
{{- end }}
    }
{{- else }}
    public init() {}
{{- end }}

    public func {{ .SerializeMethod }}() -> [String: Any] {
{{- if $hasRequired }}
        var props: [String: Any] = [
{{- $needComma := false }}
{{- range .Properties }}
{{- if not .Optional }}
{{- if $needComma }},{{ end }}
            "{{ escapeString .SerialName }}": {{ .SerializeExpr }}
{{- $needComma = true }}
{{- end }}
{{- end }}
        ]
{{- else }}
        var props: [String: Any] = [:]
{{- end }}
{{- range .Properties }}
{{- if .Optional }}
        if let {{ .Name }} = {{ .Name }} { props["{{ escapeString .SerialName }}"] = {{ .SerializeExpr }} }
{{- end }}
{{- end }}
        return props
    }
}
{{- end }}
{{- end }}
