// MARK: - RudderTyperAnalytics

/// Type-safe wrappers for RudderStack tracking based on your Tracking Plan.
///
/// Tracking Plan: {{ if .TrackingPlanURL }}{{ .TrackingPlanName }} ({{ .TrackingPlanURL }}){{ else }}{{ .TrackingPlanName }}{{ end }}
/// - ID: {{ .TrackingPlanID }}
/// - Version: {{ .TrackingPlanVersion }}
///
/// ## Quick Start
/// ```swift
/// let analytics = Analytics(configuration: Configuration(
///     writeKey: "YOUR_WRITE_KEY",
///     dataPlaneUrl: "YOUR_DATA_PLANE_URL"
/// ))
/// let rudderTyper = RudderTyperAnalytics(analytics: analytics)
/// ```
public class RudderTyperAnalytics {
    private let analytics: Analytics

    public init(analytics: Analytics) {
        self.analytics = analytics
    }

    // MARK: - Events
{{ range .AnalyticsMethods }}
    /// {{ escapeComment .Comment }}
    /// - Parameters:
{{- range .MethodArguments }}
    ///   - {{ .Name }}:{{ if .Comment }} {{ escapeComment .Comment }}{{ end }}
{{- end }}
    ///   - options: Optional RudderOption for additional event configuration
    public func {{ .Name }}(
{{- range $i, $arg := .MethodArguments }}
{{- if $i }},
        {{ end }}{{ $arg.Name }}: {{ $arg.Type }}{{- if $arg.Optional }}?{{ end }}{{- if $arg.Default }} = {{ $arg.Default }}{{ end }}
{{- end }}
{{- if .MethodArguments }},
        {{ end }}options: RudderOption? = nil
    ) {
        analytics.{{ .SDKMethodName }}(
{{- range .SDKArguments }}
            {{ .Label }}: {{- if .ShouldSerialize }} {{ .Value }}.toProperties(){{- else if .IsLiteral }} {{ formatLiteral .Value }}{{- else }} {{ .Value }}{{- end }},
{{- end }}
            options: withRudderTyperContext(options: options)
        )
    }
{{ end }}
    // MARK: - Private Helpers

    {{- /*
        withRudderTyperContext injects RudderTyper metadata into every event's context.
        RudderTyper context wins on merge — user's customContext is the base,
        rudderTyperContext overwrites on key collision.
        This differs from Kotlin where user context wins.
    */ -}}
    private func withRudderTyperContext(options: RudderOption?) -> RudderOption {
        let rudderTyperContext: [String: Any] = [
            "ruddertyper": [
{{- range $key, $value := .EventContext }}
                "{{ escapeString $key }}": {{ $value }},
{{- end }}
            ] as [String: Any]
        ]

        if let options = options {
            let mergedContext = (options.customContext ?? [:]).merging(rudderTyperContext) { _, new in new }
            return RudderOption(
                integrations: options.integrations,
                customContext: mergedContext,
                externalIds: options.externalIds
            )
        } else {
            return RudderOption(customContext: rudderTyperContext)
        }
    }
}
